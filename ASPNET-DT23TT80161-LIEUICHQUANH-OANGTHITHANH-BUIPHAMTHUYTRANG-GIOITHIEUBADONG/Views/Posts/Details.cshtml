@model BaDongTourism.Models.Post

@{
    ViewData["Title"] = Model.Title;
}

<section class="container my-5">
    <div class="card shadow-sm">
        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/badong1.jpg" : Model.ImageUrl)"
             class="post-detail-img"
             alt="@Model.Title" />

        <div class="card-body">
            <span class="badge bg-primary mb-2">@Model.Category?.Name</span>

            <h2>@Model.Title</h2>

            <p class="text-muted">
                Ngày đăng: @Model.CreatedAt.ToString("dd/MM/yyyy")
            </p>

            <p class="lead">@Model.Summary</p>

            <hr />

            <p style="white-space: pre-line;">
                @Model.Content
            </p>

            <a asp-controller="Posts" asp-action="Index" class="btn btn-secondary mt-3">
                Quay lại danh sách
            </a>
        </div>
    </div>
</section>
