@model BaDongTourism.Models.Post

@{
    ViewData["Title"] = "Chi tiết bài viết";
}

<h2>Chi tiết bài viết</h2>

<div class="card shadow-sm bg-white">
    <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/badong1.jpg" : Model.ImageUrl)"
         style="max-height: 350px; object-fit: cover;"
         class="card-img-top" />

    <div class="card-body">
        <span class="badge bg-primary mb-2">@Model.Category?.Name</span>

        <h3>@Model.Title</h3>

        <p class="text-muted">
            Ngày tạo: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
        </p>

        <p><strong>Tóm tắt:</strong> @Model.Summary</p>

        <hr />

        <p style="white-space: pre-line;">@Model.Content</p>

        <a asp-area="Admin" asp-controller="Posts" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            Sửa
        </a>

        <a asp-area="Admin" asp-controller="Posts" asp-action="Index" class="btn btn-secondary">
            Quay lại
        </a>
    </div>
</div>