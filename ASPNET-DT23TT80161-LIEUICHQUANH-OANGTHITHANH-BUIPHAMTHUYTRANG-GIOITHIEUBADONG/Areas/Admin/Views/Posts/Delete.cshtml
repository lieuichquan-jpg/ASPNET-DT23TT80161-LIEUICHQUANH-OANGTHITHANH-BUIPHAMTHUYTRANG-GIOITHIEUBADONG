@model BaDongTourism.Models.Post

@{
    ViewData["Title"] = "Xóa bài viết";
}

<h2>Xóa bài viết</h2>

<div class="alert alert-danger">
    Bạn có chắc chắn muốn xóa bài viết này không?
</div>

<div class="card shadow-sm bg-white">
    <div class="card-body">
        <h4>@Model.Title</h4>

        <p><strong>Danh mục:</strong> @Model.Category?.Name</p>

        <p><strong>Tóm tắt:</strong> @Model.Summary</p>

        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/badong1.jpg" : Model.ImageUrl)"
             style="width: 250px; height: 150px; object-fit: cover;"
             class="rounded border mb-3" />

        <form asp-area="Admin" asp-controller="Posts" asp-action="Delete" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-danger">
                Xác nhận xóa
            </button>

            <a asp-area="Admin" asp-controller="Posts" asp-action="Index" class="btn btn-secondary">
                Hủy
            </a>
        </form>
    </div>
</div>