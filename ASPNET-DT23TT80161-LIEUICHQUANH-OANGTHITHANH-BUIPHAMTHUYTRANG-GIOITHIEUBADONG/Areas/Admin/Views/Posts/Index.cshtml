@model IEnumerable<BaDongTourism.Models.Post>

@{
    ViewData["Title"] = "Quản lý bài viết";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Quản lý bài viết</h2>

    <a asp-area="Admin" asp-controller="Posts" asp-action="Create" class="btn btn-primary">
        Thêm bài viết
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<table class="table table-bordered table-striped bg-white shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Ảnh</th>
            <th>Tiêu đề</th>
            <th>Danh mục</th>
            <th>Ngày tạo</th>
            <th style="width: 230px;">Thao tác</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/badong1.jpg" : item.ImageUrl)"
                         style="width: 90px; height: 60px; object-fit: cover;"
                         class="rounded" />
                </td>

                <td>@item.Title</td>

                <td>@item.Category?.Name</td>

                <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>

                <td>
                    <a asp-area="Admin" asp-controller="Posts" asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                        Xem
                    </a>

                    <a asp-area="Admin" asp-controller="Posts" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                        Sửa
                    </a>

                    <a asp-area="Admin" asp-controller="Posts" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                        Xóa
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>