@{
    ViewData["Title"] = "Đăng nhập Admin";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Đăng nhập Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container">
        <div class="admin-box">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0">Đăng nhập Admin</h4>
                </div>

                <div class="card-body">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Error
                        </div>
                    }

                    <form asp-area="Admin" asp-controller="Account" asp-action="Login" method="post">
                        <div class="mb-3">
                            <label class="form-label">Tên đăng nhập</label>
                            <input type="text" name="username" class="form-control" placeholder="Nhập admin" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Mật khẩu</label>
                            <input type="password" name="password" class="form-control" placeholder="Nhập 123456" required />
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            Đăng nhập
                        </button>
                    </form>

                    <div class="text-center mt-3">
                        <a asp-area="" asp-controller="Home" asp-action="Index">Quay lại website</a>
                    </div>

                    <div class="alert alert-info mt-3 mb-0">
                        <strong>Tài khoản demo:</strong><br />
                        Username: admin<br />
                        Password: 123456
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>